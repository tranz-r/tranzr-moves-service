{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "TranzrMovesDatabaseConnection": "Server=localhost;Port=5432;Database=tranzr;User Id=tranzr;Password=tranzr;",
    "redis": "localhost:6379",
    "rabbitmq": "amqp://guest:guest@localhost:5672"
  },
  "PayLater": {
    "RecoveryIntervalMinutes": 90,
    "UseDurableMessaging": true
  },
  "QuoteReminders": {
    "Enabled": true,
    "ScanIntervalMinutes": 60,
    "IdleHoursBeforeReminder": 24,
    "ReminderCooldownDays": 7,
    "FrontendBaseUrl": "http://localhost:3000",
    "ResumeTokenLifetimeDays": 30
  }
}
