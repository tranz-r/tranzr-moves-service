<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="format-detection" content="telephone=no">
    <meta name="format-detection" content="date=no">
    <meta name="format-detection" content="address=no">
    <meta name="format-detection" content="email=no">
    <title>Checkout Link - {{quoteReference}}</title>
    <!--[if mso]>
    <noscript>
        <xml>
            <o:OfficeDocumentSettings>
                <o:PixelsPerInch>96</o:PixelsPerInch>
            </o:OfficeDocumentSettings>
        </xml>
    </noscript>
    <![endif]-->
    <style type="text/css">
{{> shared-email-styles}}
    </style>
</head>
<body>
    <div class="email-container">
        <div class="header">
            {{> email-header-logo}}
            <h1>Checkout Link Ready</h1>
            <p>Quote #{{quoteReference}}</p>
        </div>
        <div class="content">
            <div class="greeting">Hello {{customerName}},</div>
            
            <div class="main-text">
                Your secure checkout link is ready. Click the button below to complete your payment for your Tranzr Moves service.
            </div>
            
            <div class="payment-details">
                <div class="payment-row">
                    <span class="payment-label">Quote Reference:</span>
                    <span class="payment-value">#{{quoteReference}}</span>
                </div>
                <div class="payment-row">
                    <span class="payment-label">Amount:</span>
                    <span class="payment-value amount">£{{paymentAmount}}</span>
                </div>
                <div class="payment-row">
                    <span class="payment-label">Description:</span>
                    <span class="payment-value">{{description}}</span>
                </div>
            </div>
            
            <div style="text-align: center;">
                <a href="{{checkoutUrl}}" class="button">Complete Payment</a>
            </div>
            
            <div class="security-notice">
                <h3>Secure Checkout</h3>
                <p>This checkout link is secured by Stripe and will expire after 24 hours for your security.</p>
            </div>
            
            <div class="main-text">
                <p><strong>What happens next?</strong></p>
                <ul style="margin-left: 20px; margin-top: 10px;">
                    <li>Click the checkout button above to complete your payment</li>
                    <li>You'll be redirected to our secure checkout page</li>
                    <li>Once payment is confirmed, you'll receive a confirmation email</li>
                    <li>Our team will contact you to finalize your moving details</li>
                </ul>
            </div>
            
            <div class="main-text">
                <p><strong>Need help?</strong> If you have any questions about this checkout or your quote, please contact our support team at support@tranzrmoves.com or call us at 0303 330 1101.</p>
            </div>
            
            <div class="transactional-note">
                <p>You received this email because you requested a checkout link for quote #{{quoteReference}}. If you have any concerns about this email, please contact us at support@tranzrmoves.com.</p>
            </div>
        </div>
        {{> email-footer-html}}
    </div>
</body>
</html>